# ---------------------------------------------------------------------------
# Petal & Prosper — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` for local development. On Railway, set these as
# service variables in the dashboard (Postgres-provided vars are injected
# automatically; everything else is your responsibility).
# ---------------------------------------------------------------------------

# Database ------------------------------------------------------------------
# Local: point at your local Postgres.
# Railway: the Postgres plugin sets this automatically via the
# `postgres.railway.internal` host. No action needed in prod.
DATABASE_URL="postgresql://user:password@localhost:5432/petal_and_prosper"

# Auth (NextAuth v5) --------------------------------------------------------
# AUTH_SECRET is used to sign and verify JWT session tokens. Generate with:
#   openssl rand -base64 32
# AUTH_URL must be the canonical URL of the deployed app (no trailing slash).
# NextAuth v5 reads AUTH_SECRET/AUTH_URL first, falling back to the legacy
# NEXTAUTH_SECRET/NEXTAUTH_URL names, so set whichever pair you prefer.
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Optional: public base URL used when generating public links (proposal
# accept pages, password-reset emails). Falls back to the incoming request
# origin if unset. Set this on Railway to your canonical domain.
# NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"
# APP_URL is an older fallback read by the same helpers; either works.
# APP_URL="https://your-app.up.railway.app"

# Email ---------------------------------------------------------------------
# Email dispatch is currently STUBBED. `src/lib/email/send.ts` logs every
# outgoing email to stderr and returns success without actually sending.
# Nothing to configure. When we wire SMTP back in we'll document the vars
# here (SMTP_URL, EMAIL_FROM, etc.).

# Google Maps ---------------------------------------------------------------
# Two separate keys: one for server-side calls (geocoding, distance matrix,
# route optimisation) and one for the client-side Maps JS loader that
# renders the delivery map + route planner. In practice these can point at
# the same Google Cloud project but need different API restrictions: the
# public key must be restricted by HTTP referrer, the server key by IP.
# If either is missing the corresponding feature degrades gracefully
# (distance calls return null, map renders a placeholder).
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Anthropic -----------------------------------------------------------------
# Powers the AI Invoice Scanner (PDF → line items) and the delivery
# schedule suggestion. If unset, those two features throw at call time;
# the rest of the app is unaffected.
ANTHROPIC_API_KEY=""

# OpenAI --------------------------------------------------------------------
# Used by the product image generator in the libraries flow. If unset,
# the "Generate Image" button returns an error; everything else works.
OPENAI_API_KEY=""

# Cloudflare R2 (image storage) --------------------------------------------
# Product photos, mood board uploads, and PDF exports are stored in an R2
# bucket (S3-compatible). Images are served from a public URL so the SDK
# only needs put/delete credentials. If these are unset, image uploads
# throw at call time -- the rest of the app is unaffected.
#
# Setup:
#   1. Cloudflare dashboard -> R2 -> Create bucket (choose EU jurisdiction).
#   2. R2 -> Manage API tokens -> create a token with "Object Read & Write"
#      scoped to this bucket. Copy the access key ID and secret.
#   3. Bucket -> Settings -> Public access -> enable the r2.dev subdomain
#      (or attach a custom domain later and update R2_PUBLIC_URL).
#   4. Paste the values below.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="petal-and-prosper-images"
# Public base URL for reads. With a custom domain this is e.g.
# https://images.petalandprosper.com; otherwise it's the pub-*.r2.dev
# URL Cloudflare assigns when public access is enabled.
R2_PUBLIC_URL=""

# Feature flags -------------------------------------------------------------
# Gate unfinished features behind flags. Unset = off.
# NEXT_PUBLIC_FEATURE_SUBSCRIPTION="1"

# Seed safety ---------------------------------------------------------------
# `npm run db:seed` refuses to run when NODE_ENV=production unless this
# is set to "true". Don't enable it unless you really mean it.
# ALLOW_PROD_SEED="false"
